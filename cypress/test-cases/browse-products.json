{
  "feature": "Browse Products",
  "story": "As a shopper, I want to land on the Eclat shop and immediately see the catalogue so I can decide what to buy.",
  "cases": [
    {
      "id": "TC-01",
      "title": "Grid renders on load",
      "given": "User opens /eclat-shop.html",
      "when": "the page finishes rendering",
      "then": "at least one .pcard is visible",
      "selectors_hint": [
        "#grid",
        ".pcard"
      ],
      "priority": "high"
    },
    {
      "id": "TC-02",
      "title": "Each product card shows name, category, and price",
      "given": "Grid is rendered",
      "when": "user inspects the first .pcard",
      "then": ".pcard-name, .pcard-cat, and .pcard-price are all visible and non-empty",
      "selectors_hint": [
        ".pcard",
        ".pcard-name",
        ".pcard-cat",
        ".pcard-price"
      ],
      "priority": "medium"
    },
    {
      "id": "TC-03",
      "title": "Results info reflects visible product count",
      "given": "Grid is rendered",
      "when": "the page finishes rendering",
      "then": "#results-info text matches the number of visible .pcard elements",
      "selectors_hint": [
        "#results-info",
        ".pcard"
      ],
      "priority": "medium"
    },
    {
      "id": "TC-04",
      "title": "Cart starts empty and checkout button is disabled",
      "given": "User opens /eclat-shop.html",
      "when": "the page finishes rendering",
      "then": "#cart-count shows 0 and #checkout-btn is disabled",
      "selectors_hint": [
        "#cart-count",
        "#checkout-btn"
      ],
      "priority": "high"
    }
  ]
}