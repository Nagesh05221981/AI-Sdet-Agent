{
  "feature": "Filter By Category",
  "story": "As a shopper, I want to filter the product grid by category so I can browse a single section without scrolling through everything.",
  "cases": [
    {
      "id": "TC-01",
      "title": "All filter chips are visible on load",
      "given": "User opens /eclat-shop.html",
      "when": "the page finishes rendering",
      "then": "all .fchip elements are visible",
      "selectors_hint": [
        ".fchip"
      ],
      "priority": "high"
    },
    {
      "id": "TC-02",
      "title": "Clicking 'Tech' activates the filter chip",
      "given": "User sees all filter chips",
      "when": "user clicks on the 'Tech' .fchip",
      "then": "'Tech' .fchip gains the .active class",
      "selectors_hint": [
        ".fchip.active"
      ],
      "priority": "high"
    },
    {
      "id": "TC-03",
      "title": "Filtering by 'Tech' shows relevant products",
      "given": "User has activated the 'Tech' filter",
      "when": "the filter is applied",
      "then": "only products with .pcard-cat matching 'Tech' are visible and #results-info updates to reflect the new count",
      "selectors_hint": [
        ".pcard",
        "#results-info"
      ],
      "priority": "high"
    },
    {
      "id": "TC-04",
      "title": "Clicking 'All' resets the filter",
      "given": "User has filtered products by 'Tech'",
      "when": "user clicks on the 'All' .fchip",
      "then": "all products are visible again and #results-info reflects the original count",
      "selectors_hint": [
        ".fchip.active",
        "#results-info"
      ],
      "priority": "high"
    }
  ]
}