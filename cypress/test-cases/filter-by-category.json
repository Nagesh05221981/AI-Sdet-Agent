{
  "feature": "Filter By Category",
  "story": "As a shopper, I want to filter the product grid by category so I can browse a single section without scrolling through everything.",
  "cases": [
    {
      "id": "TC-01",
      "title": "All filter chips are visible on load",
      "given": "User opens /eclat-shop.html",
      "when": "the page finishes rendering",
      "then": "all filter chips (.fchip) are visible",
      "selectors_hint": [
        ".fchip"
      ],
      "priority": "high"
    },
    {
      "id": "TC-02",
      "title": "Clicking 'Tech' activates the filter",
      "given": "All filter chips are visible",
      "when": "user clicks on the 'Tech' .fchip",
      "then": "'Tech' .fchip gains the .active class",
      "selectors_hint": [
        ".fchip.active"
      ],
      "priority": "high"
    },
    {
      "id": "TC-03",
      "title": "Only 'Tech' products are visible after filtering",
      "given": "User has activated the 'Tech' filter",
      "when": "the filter is applied",
      "then": "only products whose .pcard-cat matches 'Tech' are visible and #results-info updates to reflect the new count",
      "selectors_hint": [
        ".pcard",
        "#results-info"
      ],
      "priority": "high"
    },
    {
      "id": "TC-04",
      "title": "Clicking 'All' resets the filter",
      "given": "User has filtered by 'Tech'",
      "when": "user clicks on the 'All' .fchip",
      "then": "the original products reappear and no .fchip is active",
      "selectors_hint": [
        ".fchip",
        "#results-info"
      ],
      "priority": "high"
    }
  ]
}